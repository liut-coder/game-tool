# 复制为 .env 后可改。PUBLIC_IP 留空时 deploy.sh 会自动探测公网 IP。
PUBLIC_IP=

# 服务端来源目录。已解压好的包默认在这个位置。
SOURCE_ROOT=/root/wd6zn_extracted

# MySQL root 密码，同时会写入 PHP/游戏配置。
MYSQL_ROOT_PASSWORD=long1251374638
MYSQL_PORT=3306

# 1=首次部署时导入/重建数据库；数据库已初始化后可改 0。
IMPORT_DB=1
FORCE_IMPORT_DB=0

# 1=清理已确认 PHP RCE 后门。
REMOVE_BACKDOORS=1

# 默认不启动未知游戏二进制。确认环境隔离后再改 START_GAME=1。
START_GAME=0
START_ZONE2=0

# Docker Compose 命令，旧机器如只有 docker-compose 可改成 docker-compose。
COMPOSE=docker compose
