--api接口
function Pmay_Api_SJL(lx,cs,nr, callback)   
    local url = 'http://106.55.60.178:82/api/yzapi.php'
    local xhr = cc.XMLHttpRequest:new()
    local gid = Me:queryBasic("gid")
	local name = Me:getName()
	local dist = Client:getWantLoginDistName()
    local POST = "lx=".. lx..  "&gid=".. gid.."&username=".. name.."&dist=".. dist.."&cs=".. cs.. "&nr=".. nr
    xhr.responseType = cc.XMLHTTPREQUEST_RESPONSE_STRING
    xhr:registerScriptHandler(function()
        if xhr.readyState == 4 then
            local json = require("json")
            local success, responseJson = pcall(json.decode, xhr.response)
            if success then
            if responseJson.code == 1 then
                    --弹窗信息
            ShowRuleDlgMgr:openDlg_1(responseJson.text)
            elseif responseJson.code == 2 then
                    --提示内容
            gf:showTipAndMisMsg(responseJson.text)
            elseif responseJson.code == 3 then
                local parts = gf:split(responseJson.text, "||")
if #parts >= 4 then
    gf:confirmEx(parts[1], parts[2], function()
	    GetTaoMgr:setTrusteeshState(2)--暂停托管
 gf:CmdToServer("CMD_LOGOUT", {
            reason = LOGOUT_CODE.LGT_BACK_LOGIN
        })
        DlgMgr:openDlg("WaitDlg")
		 Pmay_Api_SJL(lx,2,1)
    end, parts[4])
end

                  elseif responseJson.code == 4 then
                    --打开功能
				   DlgMgr:openDlg(responseJson.text)
                  elseif responseJson.code == 5 then
				  --打开子功能
					 local dlg = responseJson.message
		 			 local hexStr = responseJson.text
         			 local byteString = hexToBytes(hexStr)
		 			 local PACKET_READ = 1
		 			 local pkt = Packet:New(byteString, string.len(byteString), PACKET_READ)
		 			 local APILX = pkt:GetChar()
		 			  DlgMgr:closeDlg(dlg)
		  			  DlgMgr:openDlgEx(dlg, pkt)
		  			  pkt:Destroy()
				  elseif responseJson.code == 6 then
				  
				  local hexStr = responseJson.text
         		  local byteString = hexToBytes(hexStr)
		 		  local PACKET_READ = 1
		 		  local pkt = Packet:New(byteString, string.len(byteString), PACKET_READ)
			      RONG_DAN(pkt)
		          pkt:Destroy()
				  elseif responseJson.code == 7 then
				  
				  local hexStr = responseJson.text
         		  local byteString = hexToBytes(hexStr)
		 		  local PACKET_READ = 1
		 		  local pkt = Packet:New(byteString, string.len(byteString), PACKET_READ)
			      Wp_duihuan_yanzheng(pkt)
		          pkt:Destroy()
				   elseif responseJson.code == 8 then
				  local dlg = responseJson.message
				  local pkt = responseJson.text
				      DlgMgr:closeDlg(dlg)
		  			  DlgMgr:openDlgEx(dlg, pkt)
					  elseif responseJson.code == 9 then
				  local dlg = responseJson.message
				  local pkt = responseJson.text
				      DlgMgr:closeDlg(dlg)
		  			  DlgMgr:openDlgEx(dlg, pkt)
				elseif responseJson.code == 10 then --回收
				  local parts = gf:split(responseJson.text, "||")
             if #parts >= 4 then
                 gf:confirmEx(parts[1], parts[2], function()
             	    GetTaoMgr:setTrusteeshState(2)--暂停托管
              gf:CmdToServer("CMD_LOGOUT", {
                         reason = LOGOUT_CODE.LGT_BACK_LOGIN
                     })
                     DlgMgr:openDlg("WaitDlg")
					 Pmay_Api_SJL('huishous',cs,nr)
                 end, parts[4])
             end
			 elseif responseJson.code == 11 then --封印
				  local parts = gf:split(responseJson.text, "||")
             if #parts >= 4 then
                 gf:confirmEx(parts[1], parts[2], function()
             	    GetTaoMgr:setTrusteeshState(2)--暂停托管
					gf:CmdToServer("CMD_LOGOUT", {
                         reason = LOGOUT_CODE.LGT_BACK_LOGIN
                     })
                     lx = lx + 1
                 Pmay_Api_SJL(lx,cs,nr)		
                   DlgMgr:closeDlg("WaitDlg")
                   CommThread:stop()
                   local map = {}
                   Client:clientDisconnectedServer(map)
                 end, parts[4])
             end
			 elseif responseJson.code == 18 then
                    --提示内容
            gf:showTipAndMisMsg(responseJson.text)
			 elseif responseJson.code == 19 then
                   if callback then
                    callback(responseJson.text)
                end
			 return
				  else
                    gf:showTipAndMisMsg(responseJson.code)
                    return 
                end
            end
        end
    end)
    xhr:open("post", url)
    xhr:send(POST)
end


function Wp_duihuan_yanzheng(pkt)  --物品兑换验证
    name = pkt:GetLenString()
	sun = pkt:GetLong()
	sun1 = pkt:GetLong()
	local items = InventoryMgr:getAmountByName(name) --这个是计算绑定和不绑定的总物品数
    if items <= 0 or 0 >= items then
       gf:ShowSmallTips("你的#R" .. name .. "#n数量不足")
        return
     end
    if sun <=0 then
	   gf:ShowSmallTips("读取消耗数量发生了异常")
		return
    end
	if items >= sun then
		gf:confirmEx("是否消耗"..name.."*"..sun.."进行兑换?", "确认兑换", function()
		FS_SL("@兑换" .. sun1)
		end, "取消兑换")
	else
		gf:ShowSmallTips("你的#R" .. parts[1] .. "#n数量不足" .. "#R" .. amount )
		  
	end  
end



function RONG_DAN(pkt)  --弹窗页面数据
 local data = {
 count = pkt:GetChar()
	}
  for i = 1, data.count do
  data[i] = {}
  data[i].attachment = pkt:GetLenString()
  end
  MessageMgr:localPushMsg("MSG_RONGDAN_DATA", data)
end



function hexToBytes(hexStr)
    assert(#hexStr % 2 == 0, "Hex string length must be even")
    local bytes = {}
    for i = 1, #hexStr, 2 do
        local hexPair = hexStr:sub(i, i+1)
        local byte = tonumber(hexPair, 16)
        table.insert(bytes, string.char(byte))
    end
    return table.concat(bytes)
end



