function SystemFunctionDlg:initBtnCfg()
	btnPosMap = {}

	for i = 1, #FIRST_ROW_BTN_LIST do
		btnPosMap[FIRST_ROW_BTN_LIST[i]] = i
	end

	for i = 1, #RIGHT_EXTEND_BTN_LIST do
		btnPosMap[RIGHT_EXTEND_BTN_LIST[i]] = 100 + i
	end

	for i = 1, #DOWN_EXTEND_BTN_LIST do
		btnPosMap[DOWN_EXTEND_BTN_LIST[i]] = 200 + i
	end
end

