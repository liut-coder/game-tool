function SystemFunctionDlg:initCfgBtns()
	for name, value in pairs(BTN_CFG) do
		local btn = ccui.Button:create()

		btn:ignoreContentAdaptWithSize(false)
		btn:setContentSize(cc.size(BUTTON_SIZE, BUTTON_SIZE))
		btn:loadTextureNormal(value.icon, value.plistType)
		btn:setName(name)
		btn:setVisible(true)
		self.root:addChild(btn)

		if value.listenerFun then
			self:bindListener(name, self[value.listenerFun])
		else
			self:bindListener(name, self["on" .. name])
		end
	end
end

function SystemFunctionDlg:setVisible(show)
	if DlgMgr:isDlgOpened("UndergroundMainDlg") or DlgMgr:isDlgOpened("YijxbDlg") then
		Dialog.setVisible(self, false)
	else
		Dialog.setVisible(self, show)
	end
end

function SystemFunctionDlg:setStatusButtonPos()
	local winSize = self:getWinSize()
	local width = winSize.width / Const.UI_SCALE
	local height = winSize.height / Const.UI_SCALE
	local mapSize = self:getControl("SmallMapButton"):getContentSize()
	local statusButton = self:getControl("StatusButton1")

	statusButton:setPosition(BUTTON_SIZE / 2 + EDG_MARGIN, height - mapSize.height - BUTTON_SIZE / 2)

	local statusButton = self:getControl("StatusButton2")

	statusButton:setPosition(BUTTON_SIZE / 2 + EDG_MARGIN, height - mapSize.height - BUTTON_SIZE / 2)
end

function SystemFunctionDlg:MSG_UPDATE()
	if Me:queryBasicInt("enable_double_points") == 1 then
		local point = Me:queryBasicInt("double_points")

		self:setLabelText("DoublePointLabel", point .. CHS[3003690])
		self:setLabelText("DoublePointLabel2", point .. CHS[3003690])
		self:setCtrlVisible("DoublePointPanel", true)
	else
		self:setCtrlVisible("DoublePointPanel", false)
	end
end

function SystemFunctionDlg:updateBattery(rawlevel, scale, status, health)
	BatteryAndWifiMgr:updateBattery(self, rawlevel, scale, status, health)
end

function SystemFunctionDlg:updateNetwork(networkState)
	BatteryAndWifiMgr:updateNetwork(self, networkState)
end

function SystemFunctionDlg:updateWifiStatus(wifiState, level)
