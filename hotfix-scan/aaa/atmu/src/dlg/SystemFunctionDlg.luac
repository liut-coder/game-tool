function SystemFunctionDlg:onZyzRankButton(sender)
	if GMMgr:isGM() or TaskMgr:isZyzJournalist() then
		local campList = {
			ZYZ_CAMP.XQ,
			ZYZ_CAMP.ZG
		}

		self:popupMenus(campList, self:getBoundingBoxInWorldSpace(sender), function (index)
			ZhenYZMgr:setLeadersSummaryCamp(campList[index])
			RankMgr:clearData()
			gf:CmdToServer("CMD_CSCW_CAMP_LEADERS_INFO", {
				type = 0,
				camp = campList[index]
			})
		end)

		return
	end

	ZhenYZMgr:setLeadersSummaryCamp()
	gf:CmdToServer("CMD_CSCW_CAMP_LEADERS_INFO", {
		camp = "",
		type = 0
	})
end

function SystemFunctionDlg:onFamousButton(sender)
	if not DistMgr:checkAheadDist() then
		return
	end

	self:setCtrlVisible("HideGloryButton", false)
	self:setCtrlVisible("ShowGloryButton", true)

	self.isOpenGlory = false

	self:playAnim(0)
end

function SystemFunctionDlg:onGiftsButton(sender)
	if not DistMgr:checkCrossDist() then
		return
	end

	GiftMgr:openGift(true)

	sender = sender or self:getControl("GiftsButton")
	local magic = sender:getChildByTag(Const.ARMATURE_MAGIC_TAG)

	if magic then
		magic:removeFromParent()
	end
end

function SystemFunctionDlg:displayShowGloryButton()
	self.isOpenGlory = false

	self:setCtrlVisible("HideGloryButton", false)
	self:setCtrlVisible("ShowGloryButton", true)
end

function SystemFunctionDlg:onGloryButton()
	RedDotMgr:removeOneRedDot("SystemFunctionDlg", "GloryButton")

	if not self.isOpenGlory then
		self.isOpenGlory = true

		self:setCtrlVisible("HideGloryButton", true)
		self:setCtrlVisible("ShowGloryButton", false)

		if self.isOpenGlory then
			if self.gloryButtonSeq then
				self.root:stopAction(self.gloryButtonSeq)
			end

			self.gloryButtonSeq = performWithDelay(self.root, function ()
				if self.isOpenGlory then
					self:onGloryButton()
				end

				self.gloryButtonSeq = nil
			end, NOT_OPERATE_SECONDS)
		end
	else
		self:displayShowGloryButton()
	end
end

function SystemFunctionDlg:playAnimChangeDlgStatu(bool)
end

function SystemFunctionDlg:playAnim(frameNum)
	local sz = self.root:getContentSize()
	local magic = ArmatureMgr:createArmature(ResMgr.ArmatureMagic.famous_entry.name)

	magic:setPosition(sz.width / 2, sz.height / 2)
	gf:getTopLayer():addChild(magic, 3)

	local anim = magic:getAnimation()

	anim:play("Top")

	local frame = cc.Director:getInstance():getAnimationInterval()

	if frameNum == 0 then
		self:playAnimChangeDlgStatu(false)
		gf:frozenScreen(0, 0.8, frame * 25)
		performWithDelay(self.root, function ()
			local dlg = DlgMgr:openDlg("FamousDlg")

			DlgMgr:sendMsg("FamousDlg", "playAnim", 30)
			dlg:setData(self.famousData)
			gf:unfrozenScreen()
		end, frame * 30)
	elseif frameNum == 30 then
		gf:frozenScreen(0, 0.8, frame * 25)
		anim:gotoAndPlay(30)
		performWithDelay(self.root, function ()
			self:playAnimChangeDlgStatu(false)
		end, 0)
		performWithDelay(self.root, function ()
			self:playAnimChangeDlgStatu(true)
			gf:unfrozenScreen()
		end, frame * 15)
	end
end

function SystemFunctionDlg:MSG_OPEN_WELFARE()
	local welfareData = GiftMgr:getWelfareData()
	local timeCountLabel = self:getControl("CountDownLabel")
	local timeCountLabel2 = self:getControl("CountDownLabel2")

	if welfareData.leftTimes > 0 and welfareData.times == 0 then
		self:setCtrlVisible("CountDownPanel", true)

		local time = welfareData.leftTime

		timeCountLabel:setString(self:getTimeStr(time))
		timeCountLabel:stopAllActions()
		schedule(timeCountLabel, function ()
			if time == 0 then
				GiftMgr:openGift()
				timeCountLabel:stopAllActions()

				return
			end

			time = time - 1

			timeCountLabel:setString(self:getTimeStr(time))
			timeCountLabel2:setString(self:getTimeStr(time))
		end, 1)

		return
	end

	self:setCtrlVisible("CountDownPanel", false)
end

function SystemFunctionDlg:getTimeStr(time)
	local hours = math.floor(time / 3600)
	local minute = math.floor(time % 3600 / 60)
	local second = time % 60
	local str = string.format("%02d:%02d", minute, second)

	return str
end

